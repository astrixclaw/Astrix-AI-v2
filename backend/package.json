{
  "name": "astrix-home-backend",
  "version": "0.1.0",
  "description": "Backend service for Astrix Home — auth, chat, Hue lighting, group chat.",
  "private": true,
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/websocket": "^10.0.1",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.3.0",
    "fastify": "^4.28.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.5.5",
    "pino-pretty": "^11.2.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "undici": "^8.4.1"
  },
  "engines": {
    "node": ">=20"
  }
}
